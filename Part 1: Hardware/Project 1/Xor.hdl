/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Nand(a=a, b=a, out=nota);
    Nand(a=b, b=b, out=notb);

    Nand(a=b, b=nota, out=diff1);
    Nand(a=a, b=notb, out=diff2);

    Nand(a= diff1, b=diff2, out=out);

}
